@model PPL3_Banhangonline.Models.Viewmodels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Trang quản trị";
    var role = Context.Session.GetString("Role");
}

@if (role != "admin")
{
    <h1> không phận sự </h1>
}
else
{
    <div class="container mt-5">
        <div class="admin-panel shadow-lg p-4 rounded">
            <h2 class="text-center mb-2 text-primary fw-bold">Trang quản trị</h2>
            <p class="text-center text-muted mb-4">Tổng quan nhanh cho người quản trị</p>

            <div class="row g-3 mb-4">
                <div class="col-md-4 col-6">
                    <div class="stat-card">
                        <span>Tài khoản</span>
                        <strong>@Model.SoTaiKhoan</strong>
                    </div>
                </div>
                <div class="col-md-4 col-6">
                    <div class="stat-card">
                        <span>Khách hàng</span>
                        <strong>@Model.SoKhachHang</strong>
                    </div>
                </div>
                <div class="col-md-4 col-6">
                    <div class="stat-card">
                        <span>Seller</span>
                        <strong>@Model.SoSeller</strong>
                    </div>
                </div>
                <div class="col-md-6 col-6">
                    <div class="stat-card">
                        <span>Danh mục</span>
                        <strong>@Model.SoDanhMuc</strong>
                    </div>
                </div>
                <div class="col-md-6 col-12">
                    <div class="stat-card">
                        <span>Sản phẩm</span>
                        <strong>@Model.SoSanPham</strong>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card admin-card h-100 border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="icon mb-3">📂</div>
                            <h4 class="card-title">Quản lý danh mục</h4>
                            <p class="card-text text-muted">
                                Thêm, sửa, xóa và xem danh sách các danh mục sản phẩm.
                            </p>
                            <a asp-controller="Categories" asp-action="Index" class="btn btn-primary px-4">
                                Vào quản lý
                            </a>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card admin-card h-100 border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="icon mb-3">👤</div>
                            <h4 class="card-title">Quản lý người dùng</h4>
                            <p class="card-text text-muted">
                                Xem danh sách tài khoản, phân quyền và quản lý thông tin người dùng.
                            </p>
                            <a asp-controller="UserManager" asp-action="Index" class="btn btn-success px-4">
                                Vào quản lý
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <style>
        body {
        background: linear-gradient(135deg, #eef2f7, #d9e4f5);
        }

        .admin-panel {
        background: white;
        max-width: 900px;
        margin: auto;
        }

        .stat-card {
        background: linear-gradient(135deg, #f8fbff, #eef4ff);
        border: 1px solid #d8e4ff;
        border-radius: 18px;
        padding: 18px;
        text-align: center;
        box-shadow: 0 8px 20px rgba(0,0,0,0.05);
        }

        .stat-card span {
        display: block;
        color: #6b7280;
        margin-bottom: 8px;
        }

        .stat-card strong {
        display: block;
        color: #1f4e79;
        font-size: 1.5rem;
        font-weight: 700;
        }

        .admin-card {
        border-radius: 20px;
        transition: 0.3s ease;
        }

        .admin-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important;
        }

        .icon {
        font-size: 50px;
        }

        .card-title {
        font-weight: 700;
        color: #333;
        }

        .btn {
        border-radius: 30px;
        }
    </style>
}