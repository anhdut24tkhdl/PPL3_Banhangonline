@model PPL3_Banhangonline.Models.Account

@{
    ViewData["Title"] = "Sửa tài khoản";
}

<div class="container mt-4" style="max-width: 760px;">
    <h2 class="mb-4">Sửa tài khoản</h2>

    <form asp-action="EditUser" method="post" class="card shadow-sm p-4">
        <input type="hidden" asp-for="AccountId" />

        <div class="mb-3">
            <label asp-for="AccountName" class="form-label">Tên tài khoản</label>
            <input asp-for="AccountName" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Role" class="form-label">Vai trò</label>
            <select asp-for="Role" class="form-select">
                <option value="admin">admin</option>
                <option value="seller">seller</option>
                <option value="customer">customer</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Password" class="form-label">Mật khẩu mới</label>
            <input asp-for="Password" type="password" class="form-control" placeholder="Để trống nếu không đổi mật khẩu" />
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </form>
</div>