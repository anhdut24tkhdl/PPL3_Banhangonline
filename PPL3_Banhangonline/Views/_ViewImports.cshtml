@using PPL3_Banhangonline
@using PPL3_Banhangonline.Models
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Trang bán hàng";
}

<style>
    body {
        background-color: #f5f5f5;
    }

    .category-box {
        border-radius: 10px;
        overflow: hidden;
    }

        .category-box .list-group-item {
            transition: 0.3s;
            cursor: pointer;
        }

            .category-box .list-group-item:hover {
                background-color: #0d6efd;
                color: white;
            }

    .product-card {
        border-radius: 12px;
        transition: 0.3s;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }

    .product-img {
        height: 200px;
        object-fit: cover;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }

    .price {
        font-size: 18px;
        font-weight: bold;
        color: #dc3545;
    }

    .btn-cart {
        background-color: #28a745;
        color: white;
    }

        .btn-cart:hover {
            background-color: #218838;
        }
</style>

<div class="container mt-4">

    <h2 class="mb-4">🛒 Trang bán hàng</h2>

    <div class="row">

        <!-- DANH MỤC -->
        <div class="col-md-3">
            <div class="card category-box shadow-sm">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Danh mục</h5>
                </div>

                <div class="list-group list-group-flush">
                    <a class="list-group-item">Tất cả sản phẩm</a>
                    <a class="list-group-item">Thời trang nam</a>
                    <a class="list-group-item">Thời trang nữ</a>
                    <a class="list-group-item">Giày dép</a>
                    <a class="list-group-item">Phụ kiện</a>
                    <a class="list-group-item">Điện tử</a>
                </div>
            </div>
        </div>

        <!-- SẢN PHẨM -->
        <div class="col-md-9">

            <div class="row">

                <!-- CARD -->
                @for (int i = 1; i <= 6; i++)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card product-card h-100">

                            <img src="https://via.placeholder.com/300x200"
                                 class="product-img" />

                            <div class="card-body">
                                <h5 class="card-title">Sản phẩm @i</h5>
                                <p class="text-muted">Mô tả ngắn...</p>
                                <p class="price">199.000 VNĐ</p>
                            </div>

                            <div class="card-footer text-center bg-white border-0">
                                <button class="btn btn-primary btn-sm">Xem</button>
                                <button class="btn btn-cart btn-sm">Thêm giỏ</button>
                            </div>

                        </div>
                    </div>
                }

            </div>

        </div>

    </div>
</div>