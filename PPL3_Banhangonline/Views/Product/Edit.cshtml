@model PPL3_Banhangonline.Models.Product

<link rel="stylesheet" href="~/css/Product.css" />

<div class="form-container">
    <h2>Sửa sản phẩm</h2>

    <form asp-action="Edit" method="post" class="form-box">
        <input type="hidden" asp-for="ProductID" />

        <div class="form-group">
            <label>Tên sản phẩm</label>
            <input asp-for="ProductName" class="form-input" />
            <span asp-validation-for="ProductName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="Description" class="form-input form-textarea"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Giá</label>
                <input asp-for="Price" class="form-input" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Số lượng</label>
                <input asp-for="Stock" class="form-input" />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label>Ảnh (URL)</label>
            <input asp-for="Image" id="imageInput" class="form-input" />
            <span asp-validation-for="Image" class="text-danger"></span>

            <!-- Preview ảnh -->
            <div class="image-preview">
                <img id="previewImage" src="@Model.Image" alt="Preview" />
            </div>
        </div>

        <div class="form-group">
            <label>Danh mục</label>
            <select asp-for="CategoryID" asp-items="ViewBag.Categories" class="form-input">
                <option value="">-- Chọn danh mục --</option>
            </select>
            <span asp-validation-for="CategoryID" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Cập nhật</button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        const input = document.getElementById("imageInput");
        const preview = document.getElementById("previewImage");

        input.addEventListener("input", function () {
            preview.src = this.value;
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}