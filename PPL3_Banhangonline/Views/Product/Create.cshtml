@model PPL3_Banhangonline.Models.Product

<link rel="stylesheet" href="~/css/Product.css" />

<div class="form-container">
    <h2>Thêm sản phẩm</h2>

    <form asp-action="Create" method="post" class="form-box">
        <div class="form-group">
            <label>Tên sản phẩm</label>
            <input asp-for="ProductName" class="form-input" placeholder="Nhập tên sản phẩm..." />
            <span asp-validation-for="ProductName" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Mô tả</label>
            <textarea asp-for="Description" class="form-input form-textarea" placeholder="Nhập mô tả sản phẩm..."></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label>Giá</label>
                <input asp-for="Price" class="form-input" placeholder="Nhập giá sản phẩm..." />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Số lượng</label>
                <input asp-for="Stock" class="form-input" placeholder="Nhập số lượng..." />
                <span asp-validation-for="Stock" class="text-danger"></span>
            </div>
        </div>

        <div class="form-group">
            <label>Ảnh (URL)</label>
            <input asp-for="Image" class="form-input" placeholder="Dán link ảnh sản phẩm..." />
            <span asp-validation-for="Image" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Danh mục</label>
            <select asp-for="CategoryID" asp-items="ViewBag.Categories" class="form-input">
                <option value="">-- Chọn danh mục --</option>
            </select>
            <span asp-validation-for="CategoryID" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Lưu sản phẩm</button>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}