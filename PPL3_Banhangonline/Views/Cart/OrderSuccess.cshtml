@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container text-center" style="padding: 80px 0;">
    <div style="font-size: 70px; color: #28a745;">
        <i class="bi bi-check-circle-fill"></i>
    </div>
    <h2 class="mt-3" style="color: #2e7d32; font-weight: bold;">ĐẶT HÀNG THÀNH CÔNG!</h2>
    <p class="text-muted">Cảm ơn bạn đã tin tưởng GreenBasket.</p>

    <div class="alert alert-success d-inline-block mt-3 px-5">
        Mã hóa đơn của bạn là: <strong>#@ViewContext.RouteData.Values["id"]</strong>
    </div>

    <div class="mt-5">
        <a href="/" class="btn btn-success px-4 py-2" style="border-radius: 20px;">
            Tiếp tục mua sắm
        </a>
        <a asp-controller="Order" asp-action="Invoice" asp-route-id="@ViewBag.OrderId"
           class="btn btn-outline-secondary px-4 py-2 ms-2">
            Xem chi tiết hóa đơn
        </a>
    </div>
</div>