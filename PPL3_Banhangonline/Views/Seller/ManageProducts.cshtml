@using PPL3_Banhangonline.Models.Viewmodels
@model SellerProductManagementViewModel
@{
    ViewData["Title"] = "Quản lý kho hàng";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-light p-3 rounded shadow-sm">
            <li class="breadcrumb-item">
                <a asp-controller="Seller" asp-action="Index" class="text-decoration-none text-success">
                    <i class="bi bi-house-door-fill"></i> Kênh Người Bán
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Quản lý kho hàng</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4 p-4 bg-white shadow-sm rounded-4">
        <div>
            <h2 class="text-success fw-bold mb-0">📦 QUẢN LÝ KHO HÀNG</h2>
            <small class="text-muted">Cửa hàng: <span class="fw-bold text-dark">@ViewBag.ShopName</span></small>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="CreateProduct" class="btn btn-success px-4 py-2 shadow-sm fw-bold rounded-pill">
                <i class="bi bi-plus-circle-fill me-2"></i> THÊM HÀNG THƯỜNG
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        </div>
    }

    <ul class="nav nav-pills mb-3 bg-white p-2 rounded-pill shadow-sm border" id="pills-tab" role="tablist">
        <li class="nav-item w-50" role="presentation">
            <button class="nav-link active rounded-pill fw-bold w-100" id="normal-tab" data-bs-toggle="pill" data-bs-target="#tab-normal" type="button" role="tab">
                📦 SẢN PHẨM THƯỜNG (@Model.RegularProducts.Count)
            </button>
        </li>
        <li class="nav-item w-50" role="presentation">
            <button class="nav-link rounded-pill fw-bold w-100 text-danger" id="rescue-tab" data-bs-toggle="pill" data-bs-target="#tab-rescue" type="button" role="tab">
                🆘 CHIẾN DỊCH GIẢI CỨU (@Model.RescueCampaigns.Count)
            </button>
        </li>
    </ul>

    <div class="tab-content mt-4" id="pills-tabContent">
        <div class="tab-pane fade show active" id="tab-normal" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-success">
                            <tr>
                                <th class="ps-4">Sản phẩm</th>
                                <th>Đơn giá</th>
                                <th>Tồn kho</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.RegularProducts)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <img src="@item.Image" class="rounded-3 shadow-sm me-3"
                                                 style="width: 55px; height: 55px; object-fit: cover;" onerror="this.src='/images/no-image.png'" />
                                            <div>
                                                <div class="fw-bold text-dark">@item.ProductName</div>
                                                <small class="text-muted">ID: #@item.ProductID</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td><span class="fw-bold text-success">@item.Price?.ToString("N0")₫</span></td>
                                    <td>
                                        <span class="badge @(item.Stock < 5 ? "bg-danger" : "bg-light text-dark border")">
                                            @item.Stock
                                        </span>
                                    </td>
                                    <td>
                                        <span class="small @(item.Stock > 0 ? "text-primary" : "text-danger")">
                                            <i class="bi bi-circle-fill fs-6 me-1" style="font-size: 8px !important;"></i>
                                            @(item.Stock > 0 ? "Đang bán" : "Hết hàng")
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            <a asp-action="EditProduct" asp-route-id="@item.ProductID" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil-square"></i></a>
                                            <a asp-action="DeleteProduct" asp-route-id="@item.ProductID" class="btn btn-outline-danger btn-sm" onclick="return confirm('Xác nhận xóa?')"><i class="bi bi-trash-fill"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-rescue" role="tabpanel">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-danger text-white">
                            <tr>
                                <th class="ps-4">Mặt hàng giải cứu</th>
                                <th>Lý do</th>
                                <th>Giá giải cứu</th>
                                <th>Ngày Kết Thúc</th>
                                <th>Trạng thái</th>
                                <th class="text-end pe-4">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rc in Model.RescueCampaigns)
                            {
                                // Tính tổng số lượng khách đã đăng ký giúp (nếu có danh sách Registrations)
                                var totalReg = rc.Registrations?.Sum(r => r.Quantity) ?? 0;
                                var isExpired = rc.ExpectedHarvestDate.HasValue && rc.ExpectedHarvestDate < DateTime.Now;
                                var isClosed = rc.Status == "Closed";

                                <tr class="@(isClosed || isExpired ? "opacity-75" : "")">
                                    <td class="ps-4">
                                        <div class="fw-bold text-danger">@rc.ProductName</div>
                                        <div class="small text-muted">@rc.Category?.CategoryName</div>
                                        @* Hiển thị tiến độ gom hàng *@
                                        <div class="mt-1">
                                            <span class="badge bg-light text-success border border-success shadow-sm">
                                                <i class="bi bi-people-fill"></i> Đã gom: <strong>@totalReg</strong> Kg
                                            </span>
                                        </div>
                                    </td>

                                    <td><div class="text-truncate" style="max-width: 180px;" title="@rc.Reason">@rc.Reason</div></td>

                                    <td>
                                        <div class="fw-bold text-danger">@rc.Price.ToString("N0")₫</div>
                                        <small class="text-muted">Tối thiểu: @rc.MinQuantity Kg</small>
                                    </td>

                                    @* Ngày kết thúc (Hiện cả Giờ:Phút) *@
                                    <td>
                                        @if (rc.ExpectedHarvestDate.HasValue)
                                        {
                                            <div class="fw-bold @(isExpired ? "text-muted" : "text-dark")">
                                                <i class="bi bi-clock-fill me-1"></i> @rc.ExpectedHarvestDate.Value.ToString("HH:mm")
                                            </div>
                                            <div class="small">@rc.ExpectedHarvestDate.Value.ToString("dd/MM/yyyy")</div>

                                            @if (!isExpired && !isClosed)
                                            {
                                                var timeLeft = rc.ExpectedHarvestDate.Value - DateTime.Now;
                                                <small class="text-primary fw-bold">
                                                    (Còn @(timeLeft.Days > 0 ? timeLeft.Days + "n " : "") @timeLeft.Hours h @timeLeft.Minutes m)
                                                </small>
                                            }
                                        }
                                    </td>

                                    @* Trạng thái chi tiết *@
                                    <td>
                                        @if (isClosed)
                                        {
                                            <span class="badge bg-secondary"><i class="bi bi-lock-fill"></i> ĐÃ CHỐT ĐƠN</span>
                                        }
                                        else if (isExpired)
                                        {
                                            <span class="badge bg-dark">HẾT HẠN</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success shadow-sm">ĐANG CHẠY</span>
                                        }
                                    </td>

                                    @* Thao tác *@
                                    <td class="text-end pe-4">
                                        <div class="btn-group">
                                            @* Chỉ hiện nút Chốt đơn nếu đang Active và chưa hết hạn *@
                                            @if (!isClosed && !isExpired)
                                            {
                                                <form asp-action="CloseCampaign" asp-controller="Seller" method="post"
                                                      onsubmit="return confirm('Bạn muốn chốt đơn sớm chiến dịch này? Sau khi chốt khách sẽ không thể đăng ký thêm.')">
                                                    <input type="hidden" name="id" value="@rc.CampaignID" />
                                                    <button type="submit" class="btn btn-sm btn-danger px-3 shadow-sm" title="Chốt đơn sớm">
                                                        <i class="bi bi-check-all"></i> CHỐT SỚM
                                                    </button>
                                                </form>
                                            }
                                            <a asp-action="EditCampaign" asp-controller="Rescue" asp-route-id="@rc.CampaignID"
                                               class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil"></i></a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .nav-pills .nav-link {
        color: #6c757d;
        transition: all 0.3s;
    }

        .nav-pills .nav-link.active {
            background-color: #198754 !important;
            color: white !important;
        }

    #rescue-tab.active {
        background-color: #dc3545 !important;
    }

    .table thead th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 1px;
        padding: 15px 10px;
    }

    tr:hover {
        background-color: #f8fff9 !important;
    }

    #tab-rescue tr:hover {
        background-color: #fff5f5 !important;
    }

    .rounded-4 {
        border-radius: 1rem !important;
    }
</style>