@model PPL3_Banhangonline.Models.Product
@{
    ViewData["Title"] = "Thêm nông sản mới";
}

<div class="container py-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-success text-white">
            <h4>Thêm sản phẩm mới</h4>
        </div>

        <div class="card-body">
            <form asp-action="CreateProduct" method="post">
                <div class="mb-3">
                    <label class="fw-bold">Tên nông sản</label>
                    <input asp-for="ProductName" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="fw-bold">Mô tả</label>
                    <textarea asp-for="Description"
                              class="form-control"
                              rows="4"
                              placeholder="Nhập mô tả sản phẩm..."></textarea>
                </div>

                <div class="mb-3">
                    <label class="fw-bold">Loại sản phẩm</label>
                    <select asp-for="CategoryID" class="form-select" required>
                        <option value="">-- Chọn loại --</option>
                        @foreach (var cat in ViewBag.Categories as List<Category>)
                        {
                            <option value="@cat.CategoryID">@cat.CategoryName</option>
                        }
                    </select>
                </div>

                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="fw-bold">Giá bán</label>
                        <input asp-for="Price" class="form-control" />
                    </div>

                    <div class="col-6 mb-3">
                        <label class="fw-bold">Số lượng kho</label>
                        <input asp-for="Stock" class="form-control" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="fw-bold">Link ảnh</label>
                    <input asp-for="Image" class="form-control" />
                </div>

                <button type="submit" class="btn btn-success">Đăng bán ngay</button>
                <a asp-action="ManageProducts" class="btn btn-secondary">Hủy</a>
            </form>
        </div>
    </div>
</div>