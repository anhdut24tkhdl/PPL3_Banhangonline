@model PPL3_Banhangonline.Models.Viewmodels.RegisterSellerViewModel

@{
    ViewData["Title"] = "Đăng ký Seller";
}
<link rel="stylesheet" href="~/css/register.css" />

<div class="register-page">
    <div class="register-box">
        <h2>Đăng ký Người bán hàng</h2>
        <p class="sub-text">Mở cửa hàng của bạn tại GreenBasket ngay hôm nay</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">@ViewBag.Error</div>
        }

        <form asp-action="RegisterSeller" method="post" id="registerSellerForm">

            <div class="form-group">
                <label>Tên cửa hàng</label>
                <input asp-for="ShopName" class="form-control" placeholder="Nhập tên cửa hàng của bạn" />
                <span asp-validation-for="ShopName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Mật khẩu xác nhận</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu hiện tại" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="button" class="btn-register" onclick="showConfirmModal()">Đăng ký Seller</button>

            <div class="login-link">
                Chưa muốn bán hàng?
                <a asp-controller="Home" asp-action="Index">Về trang chủ</a>
            </div>

        </form>
    </div>
</div>

<!-- Modal xác nhận -->
<div id="confirmModal" style="display:none;">
    <div class="modal-overlay" onclick="closeConfirmModal()"></div>
    <div class="modal-box">
        <h3>Xác nhận đăng ký Seller</h3>
        <p>Sau khi đăng ký, tài khoản của bạn sẽ chuyển sang vai trò <strong>Người bán hàng</strong>.</p>
        <p>Bạn có chắc chắn muốn tiếp tục không?</p>
        <div class="modal-actions">
            <button class="btn-confirm" onclick="submitForm()">Xác nhận</button>
            <button class="btn-cancel" onclick="closeConfirmModal()">Hủy</button>
        </div>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.45);
        z-index: 999;
    }

    .modal-box {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: #fff;
        border-radius: 12px;
        padding: 32px 28px;
        z-index: 1000;
        width: 380px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.18);
        text-align: center;
    }

    .modal-box h3 {
        margin-bottom: 12px;
        font-size: 1.2rem;
        color: #2d6a4f;
    }

    .modal-box p {
        color: #555;
        margin-bottom: 8px;
        font-size: 0.95rem;
    }

    .modal-actions {
        display: flex;
        gap: 12px;
        justify-content: center;
        margin-top: 20px;
    }

    .btn-confirm {
        background: #2d6a4f;
        color: #fff;
        border: none;
        padding: 10px 28px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.95rem;
        transition: background 0.2s;
    }

    .btn-confirm:hover {
        background: #1b4332;
    }

    .btn-cancel {
        background: #f0f0f0;
        color: #333;
        border: none;
        padding: 10px 28px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 0.95rem;
        transition: background 0.2s;
    }

    .btn-cancel:hover {
        background: #ddd;
    }
</style>

<script>
    function showConfirmModal() {
        // Validate form trước khi hiện modal
        const shopName = document.getElementById('ShopName').value.trim();
        const password = document.getElementById('Password').value.trim();

        if (!shopName || !password) {
            return; // Để validation mặc định của trình duyệt xử lý
        }

        document.getElementById('confirmModal').style.display = 'block';
    }

    function closeConfirmModal() {
        document.getElementById('confirmModal').style.display = 'none';
    }

    function submitForm() {
        document.getElementById('registerSellerForm').submit();
    }
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}