@model PPL3_Banhangonline.Models.Shop
@{
    ViewData["Title"] = "Trang người bán";
}

<link rel="stylesheet" href="~/css/seller.css" />

<div class="shop-page container py-4">
    <div class="shop-header text-center mb-5">
        <h1 class="display-5 fw-bold text-success">Kênh Người Bán GreenBasket</h1>
        <div class="d-inline-block p-2 px-4 bg-light rounded-pill border border-success">
            <span class="text-muted">Cửa hàng:</span>
            <strong class="text-success">@Model.ShopName</strong>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row g-4">
        <div class="col-md-4">
            <a asp-action="ManageProducts" class="card h-100 text-decoration-none border-0 shadow-sm hover-card">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">📦</div>
                    <h4 class="card-title text-dark">Quản lý sản phẩm</h4>
                    <p class="card-text text-muted small">Cập nhật kho hàng, giá cả và nông sản mới.</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="ManageOrders" class="card h-100 text-decoration-none border-0 shadow-sm hover-card">
                <div class="card-body text-center p-4 position-relative">
                    @* Thêm Badge thông báo đơn mới nếu muốn *@
                    <div class="fs-1 mb-3">🧾</div>
                    <h4 class="card-title text-dark">Xử lý đơn hàng</h4>
                    <p class="card-text text-muted small">Kiểm tra đơn mới, xác nhận và giao cho Shipper.</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="RevenueStatistics" class="card h-100 text-decoration-none border-0 shadow-sm hover-card">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">📊</div>
                    <h4 class="card-title text-dark">Doanh thu & Thống kê</h4>
                    <p class="card-text text-muted small">Xem biểu đồ tăng trưởng và tiền về ví.</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <a asp-action="EditProfile" class="card h-100 text-decoration-none border-0 shadow-sm hover-card">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">👤</div>
                    <h4 class="card-title text-dark">Thông tin cá nhân</h4>
                    <p class="card-text text-muted small">Cập nhật thông tin liên hệ của người bán.</p>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .hover-card {
        transition: all 0.3s ease;
    }

        .hover-card:hover {
            transform: translateY(-10px);
            border: 1px solid #2e7d32 !important;
        }
</style>