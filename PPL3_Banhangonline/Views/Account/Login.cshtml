@model PPL3_Banhangonline.Models.Account
@{
    ViewData["Title"] = "Đăng nhập";
}

<style>
    body {
        background: linear-gradient(135deg, #ff8c42 0%, #ff5f00 100%);
        min-height: 100vh;
    }

    .login-wrapper {
        min-height: calc(100vh - 60px);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 40px 16px;
    }

    .login-box {
        background: white;
        padding: 40px 36px;
        border-radius: 16px;
        width: 100%;
        max-width: 440px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.25);
    }

    .login-box h2 {
        text-align: center;
        margin: 0 0 28px;
        font-size: 1.6rem;
        color: #333;
    }

    .form-group {
        margin-bottom: 18px;
    }

    .form-group label {
        display: block;
        margin-bottom: 6px;
        font-weight: 600;
        font-size: 0.9rem;
        color: #444;
    }

    .form-control {
        width: 100%;
        padding: 11px 14px;
        border-radius: 8px;
        border: 1.5px solid #ddd;
        font-size: 0.95rem;
        outline: none;
        box-sizing: border-box;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        border-color: #ff8c42;
        box-shadow: 0 0 0 3px rgba(255,140,66,0.15);
    }

    .btn-login {
        width: 100%;
        padding: 12px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, #ff8c42, #ff5f00);
        color: white;
        font-size: 1rem;
        font-weight: 700;
        cursor: pointer;
        margin-top: 8px;
        transition: opacity 0.2s, transform 0.15s;
    }

    .btn-login:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    .error-msg {
        color: #e53e3e;
        font-size: 0.82rem;
        margin-top: 4px;
        display: block;
    }

    .alert-error {
        background: #fff5f5;
        border: 1px solid #fed7d7;
        color: #c53030;
        border-radius: 8px;
        padding: 10px 14px;
        text-align: center;
        margin-bottom: 18px;
        font-size: 0.9rem;
    }

    .footer-links {
        display: flex;
        justify-content: space-between;
        margin-top: 16px;
        font-size: 0.85rem;
    }

    .footer-links a {
        color: #ff8c42;
        text-decoration: none;
        font-weight: 500;
    }

    .footer-links a:hover {
        text-decoration: underline;
    }

    .divider {
        text-align: center;
        margin-top: 18px;
        color: #888;
        font-size: 0.85rem;
    }

    .divider a {
        color: #ff8c42;
        font-weight: 600;
        text-decoration: none;
    }

    .divider a:hover {
        text-decoration: underline;
    }
</style>

<div class="login-wrapper">
    <div class="login-box">
        <h2>🔐 Đăng nhập</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">@ViewBag.Error</div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Username">Tên đăng nhập</label>
                <input asp-for="Username" class="form-control" placeholder="Nhập username..." autocomplete="username" />
                <span asp-validation-for="Username" class="error-msg"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" autocomplete="current-password" />
                <span asp-validation-for="Password" class="error-msg"></span>
            </div>

            <button type="submit" class="btn-login">Đăng nhập</button>

            <div class="footer-links">
                <a href="#">Quên mật khẩu?</a>
            </div>
        </form>

        <div class="divider">
            Chưa có tài khoản? <a asp-controller="Account" asp-action="Register">Đăng ký ngay</a>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}