@model PPL3_Banhangonline.Models.Viewmodels.RegisterViewModel

@{
    ViewData["Title"] = "Đăng ký";
}
<link rel="stylesheet" href="~/css/register.css" />
<div class="register-page">
    <div class="register-box">
        <h2>Đăng ký tài khoản</h2>
        <p class="sub-text">Tạo tài khoản mới để mua sắm tại GreenBasket</p>

        @if (ViewBag.Error != null)
        {
            <div class="alert-error">@ViewBag.Error</div>
        }

        <form asp-action="Register" method="post">
            <div class="form-group">
                <label>Tên đăng nhập</label>
                <input asp-for="Username" class="form-control" placeholder="Nhập tên đăng nhập" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Mật khẩu</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Nhập mật khẩu" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Xác nhận mật khẩu</label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Họ và tên</label>
                <input asp-for="Name" class="form-control" placeholder="Nhập họ tên" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label>Số điện thoại</label>
                    <input asp-for="Phone" class="form-control" placeholder="Nhập số điện thoại" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="form-group half">
                    <label>Tuổi</label>
                    <input asp-for="Age" class="form-control" placeholder="Nhập tuổi" />
                    <span asp-validation-for="Age" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group">
                <label>Email</label>
                <input asp-for="Email" class="form-control" placeholder="Nhập email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Địa chỉ</label>
                <input asp-for="Address" class="form-control" placeholder="Nhập địa chỉ" />
                <span asp-validation-for="Address" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-register">Đăng ký</button>

            <div class="login-link">
                Đã có tài khoản?
                <a asp-controller="Account" asp-action="Login">Đăng nhập</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}