@model PPL3_Banhangonline.Models.RescueCampaign

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5 bg-danger d-flex align-items-center justify-content-center p-5 text-white">
                <div class="text-center">
                    <i class="bi bi-cart-check-fill" style="font-size: 5rem;"></i>
                    <h2 class="fw-bold mt-3">XÁC NHẬN CHUNG TAY</h2>
                    <p class="opacity-75">Hành động của bạn giúp giảm thiểu lãng phí thực phẩm!</p>
                </div>
            </div>
            <div class="col-md-7 p-5">
                <h3 class="text-success fw-bold">@Model.ProductName</h3>
                <p class="text-muted">@Model.Description</p>

                <div class="alert alert-warning border-0">
                    <strong>Thông tin giải cứu:</strong><br />
                    - Giá: <span class="text-danger fw-bold">@Model.Price.ToString("N0")đ</span><br />
                    - Tối thiểu: @Model.MinQuantity kg/đơn
                </div>

                <form asp-action="ConfirmRegister" method="post" class="needs-validation">
                    <input type="hidden" name="campaignId" value="@Model.CampaignID" />

                    <div class="mb-4">
                        <label class="form-label fw-bold">Số lượng bạn đăng ký mua:</label>
                        <div class="input-group">
                            <input type="number" name="quantity" class="form-control form-control-lg border-danger"
                                   min="@Model.MinQuantity" value="@Model.MinQuantity" required />
                            <span class="input-group-text bg-danger text-white">KG</span>
                        </div>
                        <div class="form-text">Số lượng phải từ @Model.MinQuantity kg trở lên.</div>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold">
                            XÁC NHẬN LƯU VÀO HỆ THỐNG
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-link text-muted">Quay lại trang chủ</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>