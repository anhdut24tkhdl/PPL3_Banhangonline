@model PPL3_Banhangonline.Models.RescueCampaign

<div class="container py-5">
    <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="row g-0">
            <div class="col-md-5 bg-danger d-flex align-items-center justify-content-center p-5 text-white position-relative">
                <div class="text-center">
                    <i class="bi bi-hourglass-split" style="font-size: 5rem;"></i>
                    <h2 class="fw-bold mt-3">THỜI GIAN CÒN LẠI</h2>
                    @* CHỖ HIỆN ĐỒNG HỒ ĐẾM NGƯỢC *@
                    <div id="countdown" class="fs-2 fw-bold bg-white text-danger px-3 py-2 rounded-3 mt-2 shadow">
                        --:--:--
                    </div>
                </div>
            </div>
            <div class="col-md-7 p-5">
                <h3 class="text-success fw-bold">@Model.ProductName</h3>
                <p class="text-muted">@Model.Description</p>

                <div class="alert alert-warning border-0 d-flex align-items-center">
                    <i class="bi bi-info-circle-fill me-2 fs-4"></i>
                    <div>
                        Hạn chót: <strong>@Model.ExpectedHarvestDate?.ToString("HH:mm - dd/MM/yyyy")</strong>
                    </div>
                </div>

                @* KIỂM TRA ĐỂ HIỆN HOẶC ẨN FORM *@
                @if (Model.ExpectedHarvestDate > DateTime.Now)
                {
                    <form asp-action="ConfirmRegister" method="post" id="rescueForm">
                        <input type="hidden" name="campaignId" value="@Model.CampaignID" />
                        <div class="mb-4">
                            <label class="form-label fw-bold">Số lượng bạn đăng ký mua (Kg):</label>
                            <input type="number" name="quantity" class="form-control form-control-lg border-danger"
                                   min="@Model.MinQuantity" value="@Model.MinQuantity" required />
                        </div>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill fw-bold">
                                XÁC NHẬN CHUNG TAY
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <div class="alert alert-secondary text-center py-4 rounded-4">
                        <h4 class="fw-bold"><i class="bi bi-lock-fill"></i> ĐÃ ĐÓNG ĐĂNG KÝ</h4>
                        <p class="mb-0">Chiến dịch này đã quá thời hạn. Hẹn bạn ở những đợt giải cứu sau!</p>
                    </div>
                }
                <a asp-controller="Home" asp-action="Index" class="btn btn-link text-muted w-100 mt-2">Quay lại trang chủ</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function startCountdown() {
            // Lấy thời gian từ Model truyền xuống (Format chuẩn JS)
            const expiryDate = new Date("@Model.ExpectedHarvestDate?.ToString("yyyy-MM-ddTHH:mm:ss")").getTime();

            const timer = setInterval(function() {
                const now = new Date().getTime();
                const distance = expiryDate - now;

                if (distance < 0) {
                    clearInterval(timer);
                    document.getElementById("countdown").innerHTML = "HẾT HẠN";
                    // Tự động load lại trang để ẩn form khi hết hạn đúng lúc đang xem
                    location.reload();
                    return;
                }

                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                document.getElementById("countdown").innerHTML =
                    (days > 0 ? days + "d " : "") + hours + "h " + minutes + "m " + seconds + "s";
            }, 1000);
        }
        startCountdown();
    </script>
}