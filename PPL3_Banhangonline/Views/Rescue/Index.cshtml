@model IEnumerable<PPL3_Banhangonline.Models.RescueCampaign>

<div class="my-container py-5">
    <h1 class="text-danger fw-bold mb-4"><i class="bi bi-heart-fill"></i> CHIẾN DỊCH GIẢI CỨU NÔNG SẢN</h1>

    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                    <div class="bg-danger text-white p-2 text-center fw-bold">ĐANG GIẢI CỨU</div>
                    <div class="card-body">
                        <h3 class="text-success fw-bold">@item.ProductName</h3>
                        <p class="text-muted small"><strong>Lý do:</strong> @item.Reason</p>
                        <hr>
                        <div class="d-flex justify-content-between">
                            <span>Giá hỗ trợ:</span>
                            <span class="text-danger fw-bold">@item.Price.ToString("N0")đ</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span>Mua tối thiểu:</span>
                            <span class="fw-bold">@item.MinQuantity (Kg/Thùng)</span>
                        </div>

                        <form asp-action="RegisterBuy" method="post" class="mt-3">
                            <input type="hidden" name="CampaignID" value="@item.CampaignID" />
                            <div class="input-group mb-2">
                                <span class="input-group-text">Số lượng</span>
                                <input type="number" name="Quantity" class="form-control" value="@item.MinQuantity" min="@item.MinQuantity" />
                            </div>
                            <button type="submit" class="btn btn-danger w-100 fw-bold">ĐĂNG KÝ MUA NGAY</button>
                        </form>
                    </div>
                    <div class="card-footer bg-light border-0">
                        <small class="text-muted">Dự kiến thu hoạch: @item.ExpectedHarvestDate?.ToString("dd/MM/yyyy")</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>