@model PPL3_Banhangonline.Models.Category

<h2>Xóa danh mục</h2>

<p>Bạn có chắc muốn xóa danh mục này không?</p>

<div>
    <strong>ID:</strong> @Model.CategoryID
</div>

<div>
    <strong>Tên danh mục:</strong> @Model.CategoryName
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="CategoryName" />
    <button type="submit">Xóa</button>
    <a asp-action="Index">Hủy</a>
</form>